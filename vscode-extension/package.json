{
  "name": "wisp",
  "displayName": "Wisp",
  "description": "Run Wisp AI pipelines directly from your IDE",
  "version": "0.1.0",
  "publisher": "delehner",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:wisp.*",
    "workspaceContains:**/manifests/*.json",
    "workspaceContains:**/prds/**/*.md"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wisp-explorer",
          "title": "Wisp Explorer",
          "icon": "resources/wisp-icon.svg"
        }
      ]
    },
    "views": {
      "wisp-explorer": [
        {
          "id": "wispExplorer",
          "name": "Wisp Explorer",
          "when": "true"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "wisp.explorer.refresh",
          "when": "view == wispExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "wisp.explorer.orchestrate",
          "when": "viewItem == wispManifest",
          "group": "inline"
        },
        {
          "command": "wisp.explorer.openFile",
          "when": "viewItem == wispManifest"
        },
        {
          "command": "wisp.explorer.orchestrateEpic",
          "when": "viewItem == wispEpic",
          "group": "inline"
        },
        {
          "command": "wisp.explorer.runPipeline",
          "when": "viewItem == wispSubtask",
          "group": "inline"
        },
        {
          "command": "wisp.explorer.openFile",
          "when": "viewItem == wispPrd"
        }
      ]
    },
    "commands": [
      {
        "command": "wisp.showVersion",
        "title": "Wisp: Show Version"
      },
      {
        "command": "wisp.orchestrate",
        "title": "Wisp: Orchestrate Manifest"
      },
      {
        "command": "wisp.pipeline",
        "title": "Wisp: Run Pipeline"
      },
      {
        "command": "wisp.run",
        "title": "Wisp: Run Agent"
      },
      {
        "command": "wisp.generatePrd",
        "title": "Wisp: Generate PRDs"
      },
      {
        "command": "wisp.generateContext",
        "title": "Wisp: Generate Context"
      },
      {
        "command": "wisp.monitor",
        "title": "Wisp: Monitor Logs"
      },
      {
        "command": "wisp.installSkills",
        "title": "Wisp: Install Skills"
      },
      {
        "command": "wisp.update",
        "title": "Wisp: Update"
      },
      {
        "command": "wisp.stopPipeline",
        "title": "Wisp: Stop Pipeline"
      },
      {
        "command": "wisp.showOutput",
        "title": "Wisp: Show Output"
      },
      {
        "command": "wisp.explorer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "wisp.explorer.openFile",
        "title": "Open File"
      },
      {
        "command": "wisp.explorer.orchestrate",
        "title": "Run Orchestrate",
        "icon": "$(run)"
      },
      {
        "command": "wisp.explorer.orchestrateEpic",
        "title": "Run Orchestrate (this epic only)",
        "icon": "$(run)"
      },
      {
        "command": "wisp.explorer.runPipeline",
        "title": "Run Pipeline",
        "icon": "$(run)"
      }
    ],
    "configuration": {
      "title": "Wisp",
      "properties": {
        "wisp.binaryPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Path to the wisp binary. Leave empty to use PATH. This is a machine-scoped setting and cannot be overridden by workspace settings to prevent workspace-level binary hijacking."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  }
}
