{
  "name": "wisp-ai",
  "displayName": "Wisp AI",
  "description": "Run Wisp AI pipelines from your IDE — Command Palette, explorer, and live output for the wisp CLI",
  "version": "0.1.13",
  "publisher": "delehner",
  "repository": {
    "type": "git",
    "url": "https://github.com/delehner/wisp.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:wisp.*",
    "workspaceContains:**/.devenv/manifests/*.json",
    "workspaceContains:**/.devenv/prds/**/*.md"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wisp-explorer",
          "title": "Wisp AI",
          "icon": "resources/wisp-icon.svg"
        }
      ]
    },
    "views": {
      "wisp-explorer": [
        {
          "id": "wispExplorer",
          "name": "Wisp AI Explorer",
          "when": "true"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "wisp.explorer.refresh",
          "when": "view == wispExplorer",
          "group": "navigation"
        },
        {
          "command": "wisp.explorer.generateContext",
          "when": "view == wispExplorer",
          "group": "navigation"
        },
        {
          "command": "wisp.explorer.generatePrd",
          "when": "view == wispExplorer",
          "group": "navigation"
        },
        {
          "command": "wisp.explorer.installCli",
          "when": "view == wispExplorer",
          "group": "navigation"
        },
        {
          "command": "wisp.explorer.updateHomebrew",
          "when": "view == wispExplorer",
          "group": "navigation"
        },
        {
          "command": "wisp.explorer.downloadWispAssets",
          "when": "view == wispExplorer",
          "group": "navigation"
        },
        {
          "command": "wisp.explorer.configureEnv",
          "when": "view == wispExplorer",
          "group": "navigation"
        },
        {
          "command": "wisp.explorer.clearWorkDir",
          "when": "view == wispExplorer",
          "group": "navigation"
        }
      ],
      "view/item/inline": [
        {
          "command": "wisp.explorer.orchestrate",
          "when": "viewItem == wispManifest && view == wispExplorer",
          "group": "inline"
        },
        {
          "command": "wisp.explorer.generatePrd",
          "when": "viewItem == wispManifest && view == wispExplorer",
          "group": "inline"
        },
        {
          "command": "wisp.explorer.orchestrateEpic",
          "when": "viewItem == wispEpic && view == wispExplorer",
          "group": "inline"
        },
        {
          "command": "wisp.explorer.runPipeline",
          "when": "viewItem == wispSubtask && view == wispExplorer",
          "group": "inline"
        },
        {
          "command": "wisp.explorer.runPipelineFromPrd",
          "when": "viewItem == wispPrd && view == wispExplorer",
          "group": "inline"
        }
      ],
      "view/item/context": [
        {
          "command": "wisp.explorer.orchestrate",
          "when": "viewItem == wispManifest"
        },
        {
          "command": "wisp.explorer.generatePrd",
          "when": "viewItem == wispManifest"
        },
        {
          "command": "wisp.explorer.openFile",
          "when": "viewItem == wispManifest"
        },
        {
          "command": "wisp.explorer.orchestrateEpic",
          "when": "viewItem == wispEpic"
        },
        {
          "command": "wisp.explorer.runPipeline",
          "when": "viewItem == wispSubtask"
        },
        {
          "command": "wisp.explorer.runPipelineFromPrd",
          "when": "viewItem == wispPrd"
        },
        {
          "command": "wisp.explorer.openFile",
          "when": "viewItem == wispPrd"
        },
        {
          "command": "wisp.explorer.generateContext",
          "when": "view == wispExplorer"
        },
        {
          "command": "wisp.explorer.openFile",
          "when": "viewItem == wispAgentFile"
        },
        {
          "command": "wisp.explorer.openFile",
          "when": "viewItem == wispDevcontainerFile"
        }
      ]
    },
    "commands": [
      {
        "command": "wisp.showVersion",
        "title": "Wisp AI: Show Version"
      },
      {
        "command": "wisp.orchestrate",
        "title": "Wisp AI: Orchestrate Manifest"
      },
      {
        "command": "wisp.pipeline",
        "title": "Wisp AI: Run Pipeline"
      },
      {
        "command": "wisp.run",
        "title": "Wisp AI: Run Agent"
      },
      {
        "command": "wisp.generatePrd",
        "title": "Wisp AI: Generate PRDs"
      },
      {
        "command": "wisp.generateContext",
        "title": "Wisp AI: Generate Context"
      },
      {
        "command": "wisp.monitor",
        "title": "Wisp AI: Monitor Logs"
      },
      {
        "command": "wisp.installSkills",
        "title": "Wisp AI: Install Skills"
      },
      {
        "command": "wisp.downloadWispAssets",
        "title": "Wisp AI: Download Wisp Assets (.devcontainer, templates, agents)"
      },
      {
        "command": "wisp.installCli",
        "title": "Wisp AI: Install CLI (Homebrew)"
      },
      {
        "command": "wisp.updateHomebrew",
        "title": "Wisp AI: Update CLI (Homebrew)"
      },
      {
        "command": "wisp.update",
        "title": "Wisp AI: Update"
      },
      {
        "command": "wisp.configureEnv",
        "title": "Wisp AI: Configure Environment"
      },
      {
        "command": "wisp.clearWorkDir",
        "title": "Wisp AI: Clear Work Directory"
      },
      {
        "command": "wisp.stopPipeline",
        "title": "Wisp AI: Stop Pipeline"
      },
      {
        "command": "wisp.showOutput",
        "title": "Wisp AI: Show Output"
      },
      {
        "command": "wisp.explorer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "wisp.explorer.openFile",
        "title": "Open File"
      },
      {
        "command": "wisp.explorer.orchestrate",
        "title": "Run Orchestrate",
        "icon": "$(run)"
      },
      {
        "command": "wisp.explorer.orchestrateEpic",
        "title": "Run Orchestrate (this epic only)",
        "icon": "$(run)"
      },
      {
        "command": "wisp.explorer.runPipeline",
        "title": "Run Pipeline",
        "icon": "$(run)"
      },
      {
        "command": "wisp.explorer.runPipelineFromPrd",
        "title": "Run Pipeline",
        "icon": "$(run)"
      },
      {
        "command": "wisp.explorer.generatePrd",
        "title": "Generate PRDs",
        "icon": "$(add)"
      },
      {
        "command": "wisp.explorer.generateContext",
        "title": "Generate Context",
        "icon": "$(database)"
      },
      {
        "command": "wisp.explorer.installCli",
        "title": "Install CLI (Homebrew)",
        "icon": "$(cloud-download)"
      },
      {
        "command": "wisp.explorer.updateHomebrew",
        "title": "Update CLI (Homebrew)",
        "icon": "$(sync)"
      },
      {
        "command": "wisp.explorer.downloadWispAssets",
        "title": "Download Wisp assets",
        "icon": "$(desktop-download)"
      },
      {
        "command": "wisp.explorer.configureEnv",
        "title": "Configure Environment",
        "icon": "$(gear)"
      },
      {
        "command": "wisp.explorer.clearWorkDir",
        "title": "Clear Work Directory",
        "icon": "$(trash)"
      }
    ],
    "configuration": {
      "title": "Wisp AI",
      "properties": {
        "wisp.binaryPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Path to the wisp binary. Leave empty to use PATH. This is a machine-scoped setting and cannot be overridden by workspace settings to prevent workspace-level binary hijacking."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.16"
  }
}