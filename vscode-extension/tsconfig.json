{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "lib": ["ES2022"],
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "./out",
    "strict": true,
    "moduleResolution": "node16",
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["jest", "node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", ".vscode-test"]
}
