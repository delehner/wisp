# =============================================================================
# Wisp Pipeline — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# The `wisp` binary reads these from .env in the installation root directory.
# CLI flags take precedence over .env values.

# --- AI Provider ---

# Which AI CLI to use: "claude" (default) or "gemini"
# Can also be set via: wisp --provider gemini (takes precedence over .env)
# AI_PROVIDER=gemini

# --- Authentication (Claude) ---

# Anthropic API key for Claude Code (pay-per-token via console.anthropic.com).
# Leave BLANK if you use a Claude Max subscription — the CLI will use your
# Max auth automatically. Only set this if you want API credits instead.
ANTHROPIC_API_KEY=

# Optional: Claude subscription OAuth token for containerized/headless runs.
# Generate with: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# --- Authentication (Gemini) ---

# Google AI API key for Gemini CLI (from aistudio.google.com).
# Leave BLANK to use Google account auth (gemini auth login).
GEMINI_API_KEY=

# Alternative: Google Cloud API key (also accepted by Gemini CLI)
GOOGLE_API_KEY=

# --- Common ---

# GitHub personal access token (or use `gh auth login`)
GITHUB_TOKEN=

# --- Claude Code Settings ---

# Default model for Claude provider (cost-sensitive default: sonnet)
CLAUDE_MODEL=sonnet

# Allowed tools for Claude Code headless mode (ignored when using Gemini)
CLAUDE_ALLOWED_TOOLS=Edit,Write,Bash,Read,MultiEdit

# --- Gemini CLI Settings ---

# Default model for Gemini provider
GEMINI_MODEL=gemini-2.5-pro

# --- Per-Agent Model Overrides ---

# Optional per-agent model overrides (falls back to CLAUDE_MODEL or GEMINI_MODEL).
# Use provider-appropriate model names (e.g. "opus" for Claude, "gemini-2.5-flash" for Gemini).
# See src/config.rs AgentModelOverrides for the full list.
ARCHITECT_MODEL=
DESIGNER_MODEL=
MIGRATION_MODEL=
DEVELOPER_MODEL=
ACCESSIBILITY_MODEL=
TESTER_MODEL=
PERFORMANCE_MODEL=
SECOPS_MODEL=
DEPENDENCY_MODEL=
INFRASTRUCTURE_MODEL=
DEVOPS_MODEL=
ROLLBACK_MODEL=
DOCUMENTATION_MODEL=
REVIEWER_MODEL=

# --- Pipeline Defaults ---

# Maximum iterations per agent Ralph Loop (default: 10)
PIPELINE_MAX_ITERATIONS=10

# Default base branch for PRs (default: main)
DEFAULT_BASE_BRANCH=main

# Working directory for cloned repos (default: /tmp/wisp-work)
PIPELINE_WORK_DIR=/tmp/wisp-work

# Whether to clean up working directory after PR creation (default: false)
PIPELINE_CLEANUP=false

# Run agents inside Dev Containers for isolation (default: true)
USE_DEVCONTAINER=true

# Auto-update project context (CLAUDE.md or GEMINI.md) after agents finish (default: true)
UPDATE_PROJECT_CONTEXT=true

# Agents whose reports are posted as PR comments after PR creation
EVIDENCE_AGENTS=tester,performance,secops,dependency,infrastructure,devops

# Max concurrent PRD x repo pipelines when running in parallel (default: 4)
PIPELINE_MAX_PARALLEL=4

# --- Optional Integrations ---

# Notion integration token (for Notion MCP)
NOTION_TOKEN=

# Figma access token (for Figma MCP)
FIGMA_ACCESS_TOKEN=

# Slack configuration (for Slack MCP)
SLACK_TEAM_ID=

# Jira configuration (for Jira MCP)
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# --- Agent-Specific Overrides ---

# Override max iterations per agent (falls back to PIPELINE_MAX_ITERATIONS).
# See src/config.rs AgentIterationOverrides for the full list.
ARCHITECT_MAX_ITERATIONS=
DESIGNER_MAX_ITERATIONS=
MIGRATION_MAX_ITERATIONS=
DEVELOPER_MAX_ITERATIONS=
ACCESSIBILITY_MAX_ITERATIONS=
TESTER_MAX_ITERATIONS=
PERFORMANCE_MAX_ITERATIONS=
SECOPS_MAX_ITERATIONS=
DEPENDENCY_MAX_ITERATIONS=
INFRASTRUCTURE_MAX_ITERATIONS=
DEVOPS_MAX_ITERATIONS=
ROLLBACK_MAX_ITERATIONS=
DOCUMENTATION_MAX_ITERATIONS=
REVIEWER_MAX_ITERATIONS=

# --- Logging & Monitoring ---

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Log directory (default: ./logs)
LOG_DIR=./logs

# Verbose logging: show agent thinking, tool calls, and results (default: false)
VERBOSE_LOGS=false

# Interactive mode: pause between agents and iterations for review (default: false)
INTERACTIVE=false
