#!/bin/bash
set -euo pipefail

# =============================================================================
# ca — Unified CLI for the Coding Agents Pipeline
# =============================================================================
# Single entry point for all pipeline operations. Enforces two invariants:
#   - Always verbose-logs: output is always formatted through log-formatter.sh
#   - Always dev containers: agents always run inside isolated containers
#
# Usage:
#   ca orchestrate [flags]           # Run manifest orchestrator
#   ca pipeline [flags]              # Run single PRD × repo pipeline
#   ca run [flags]                   # Run a single agent (Ralph Loop)
#   ca generate prd [flags]          # Generate PRDs and manifest interactively
#   ca generate context [flags]      # Generate context skills from repo
#   ca monitor [flags]               # Tail agent logs in real-time
#   ca logs <file.jsonl>             # Re-format a .jsonl log file
#   ca help                          # Show this help

# Resolve the installation directory (where the repo lives)
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PIPELINE_DIR="$ROOT_DIR/pipeline"
LOG_DIR="${LOG_DIR:-$ROOT_DIR/logs}"

# Load provider abstraction
source "$PIPELINE_DIR/lib/provider.sh"

# --- Colors ---
if [ -t 1 ]; then
  C_RESET='\033[0m'
  C_BOLD='\033[1m'
  C_DIM='\033[2m'
  C_CYAN='\033[36m'
  C_YELLOW='\033[33m'
  C_RED='\033[31m'
  C_GREEN='\033[32m'
else
  C_RESET='' C_BOLD='' C_DIM='' C_CYAN='' C_YELLOW='' C_RED='' C_GREEN=''
fi

log() {
  local level="$1"
  local msg="$2"
  local timestamp
  timestamp=$(date '+%Y-%m-%d %H:%M:%S')
  echo -e "${C_DIM}[$timestamp]${C_RESET} ${C_CYAN}[ca]${C_RESET} [$level] $msg" >&2
}

show_help() {
  cat <<'HELP'
Usage: ca <command> [options]

Commands:
  orchestrate [flags]           Run the manifest orchestrator (orders → PRDs → repos → PRs)
  pipeline [flags]              Run a single PRD × repo pipeline
  run [flags]                   Run a single agent in a Ralph Loop
  generate prd [flags]          Generate PRDs and manifest (prompts for description)
  generate context [flags]      Generate context skills by analyzing a repository
  monitor [flags]               Tail agent logs in real-time
  logs <file.jsonl>             Re-format a raw .jsonl log file for reading
  help                          Show this help

Enforced defaults:
  --verbose-logs is always enabled (formatted output with thinking, tool calls, results)
  --no-devcontainer is blocked (agents always run inside Dev Containers)

Extra options:
  --provider <claude|gemini>    AI provider to use (default: claude, or AI_PROVIDER env var)
  --follow <agent>              Focus output on a specific agent (e.g., --follow developer)

Examples:
  # Generate context skills for a repo
  ca generate context --repo https://github.com/org/my-repo --output ./contexts/my-repo

  # Generate PRDs interactively
  ca generate prd \
    --output ./prds/my-app \
    --manifest ./manifests/my-app.json \
    --repo https://github.com/org/my-repo --context ./contexts/my-repo

  # Run the full pipeline from a manifest
  ca orchestrate --manifest ./manifests/my-app.json

  # Run with Gemini instead of Claude
  ca orchestrate --manifest ./manifests/my-app.json --provider gemini

  # Run with interactive mode (pause between agents)
  ca orchestrate --manifest ./manifests/my-app.json --interactive

  # Focus on a specific agent's output
  ca orchestrate --manifest ./manifests/my-app.json --follow developer

  # Re-read a previous session's raw logs
  ca logs ./logs/context_generator_iteration_1.jsonl

  # Monitor running agents from another terminal
  ca monitor --agent developer
HELP
}

# =============================================================================
# Filter arguments: block --no-devcontainer, inject --verbose-logs
# Stores result in FILTERED_ARGS array (avoids echo/word-splitting issues).
# =============================================================================
filter_args() {
  local inject_verbose="$1"
  shift

  local has_verbose=false
  FILTERED_ARGS=()

  for arg in "$@"; do
    if [ "$arg" = "--no-devcontainer" ]; then
      log "WARN" "Ignoring --no-devcontainer — ca always uses Dev Containers"
      continue
    fi
    if [ "$arg" = "--verbose-logs" ]; then
      has_verbose=true
    fi
    FILTERED_ARGS+=("$arg")
  done

  if [ "$inject_verbose" = true ] && [ "$has_verbose" = false ]; then
    FILTERED_ARGS+=("--verbose-logs")
  fi
}

# =============================================================================
# Extract and remove --follow and --provider from args (ca-specific flags)
# Stores result in REMAINING_ARGS array, FOLLOW_AGENT and provider vars.
# =============================================================================
extract_ca_flags() {
  FOLLOW_AGENT=""
  REMAINING_ARGS=()

  while [[ $# -gt 0 ]]; do
    if [ "$1" = "--follow" ] && [ $# -ge 2 ]; then
      FOLLOW_AGENT="$2"
      shift 2
    elif [ "$1" = "--provider" ] && [ $# -ge 2 ]; then
      export AI_PROVIDER="$2"
      shift 2
    else
      REMAINING_ARGS+=("$1")
      shift
    fi
  done
}

# =============================================================================
# Multiplexed log tailing (background watcher)
# =============================================================================
start_log_watcher() {
  local log_dir="$1"
  local follow_filter="${2:-}"

  mkdir -p "$log_dir"

  (
    trap 'exit 0' TERM INT

    declare -A seen_files 2>/dev/null || true
    local pattern

    if [ -n "$follow_filter" ]; then
      pattern="${follow_filter}_*.log"
    else
      pattern="*.log"
    fi

    while true; do
      for f in "$log_dir"/$pattern; do
        [ -f "$f" ] || continue

        local basename_f
        basename_f=$(basename "$f")

        local key="$basename_f"
        if [ -z "${seen_files[$key]:-}" ]; then
          seen_files[$key]=1
          tail -f "$f" 2>/dev/null &
        fi
      done
      sleep 2
    done
  ) &

  LOG_WATCHER_PID=$!
}

cleanup_log_watcher() {
  if [ -n "${LOG_WATCHER_PID:-}" ]; then
    kill "$LOG_WATCHER_PID" 2>/dev/null || true
    pkill -P "$LOG_WATCHER_PID" 2>/dev/null || true
    wait "$LOG_WATCHER_PID" 2>/dev/null || true
  fi
}

# =============================================================================
# Subcommand: orchestrate
# =============================================================================
cmd_orchestrate() {
  extract_ca_flags "$@"
  filter_args true "${REMAINING_ARGS[@]}"

  if [ -n "$FOLLOW_AGENT" ]; then
    log "INFO" "Following agent: $FOLLOW_AGENT"
    trap cleanup_log_watcher EXIT
    start_log_watcher "$LOG_DIR" "$FOLLOW_AGENT"
  fi

  exec "$PIPELINE_DIR/orchestrator.sh" "${FILTERED_ARGS[@]}"
}

# =============================================================================
# Subcommand: pipeline
# =============================================================================
cmd_pipeline() {
  extract_ca_flags "$@"
  filter_args true "${REMAINING_ARGS[@]}"

  if [ -n "$FOLLOW_AGENT" ]; then
    log "INFO" "Following agent: $FOLLOW_AGENT"
    trap cleanup_log_watcher EXIT
    start_log_watcher "$LOG_DIR" "$FOLLOW_AGENT"
  fi

  exec "$PIPELINE_DIR/run-pipeline.sh" "${FILTERED_ARGS[@]}"
}

# =============================================================================
# Subcommand: run (single agent)
# =============================================================================
cmd_run() {
  extract_ca_flags "$@"
  filter_args true "${REMAINING_ARGS[@]}"
  exec "$PIPELINE_DIR/run-agent.sh" "${FILTERED_ARGS[@]}"
}

# =============================================================================
# Subcommand: generate prd
# =============================================================================
cmd_generate_prd() {
  extract_ca_flags "$@"
  filter_args true "${REMAINING_ARGS[@]}"
  exec "$PIPELINE_DIR/generate-prd.sh" "${FILTERED_ARGS[@]}"
}

# =============================================================================
# Subcommand: generate context
# =============================================================================
cmd_generate_context() {
  extract_ca_flags "$@"
  # generate-context.sh uses --quiet as the inverse of verbose; default is already verbose
  local filtered=()
  for arg in "${REMAINING_ARGS[@]}"; do
    if [ "$arg" = "--quiet" ]; then
      log "WARN" "Ignoring --quiet — ca always shows formatted output"
      continue
    fi
    filtered+=("$arg")
  done

  exec "$PIPELINE_DIR/generate-context.sh" "${filtered[@]}"
}

# =============================================================================
# Subcommand: monitor
# =============================================================================
cmd_monitor() {
  exec "$PIPELINE_DIR/monitor.sh" "$@"
}

# =============================================================================
# Subcommand: logs (re-format a .jsonl file)
# =============================================================================
cmd_logs() {
  if [ $# -eq 0 ]; then
    echo "Usage: ca logs <file.jsonl> [--truncate <n>]"
    echo ""
    echo "Re-formats a raw .jsonl log file through log-formatter.sh"
    echo "for readable, color-coded output."
    echo ""
    echo "Examples:"
    echo "  ca logs ./logs/context_generator_iteration_1.jsonl"
    echo "  ca logs ./logs/developer_iteration_3.jsonl --truncate 1000"
    echo ""
    echo "Available log files:"
    if [ -d "$LOG_DIR" ]; then
      local found=false
      for f in "$LOG_DIR"/*.jsonl; do
        if [ -f "$f" ]; then
          found=true
          echo "  $(basename "$f")"
        fi
      done
      if [ "$found" = false ]; then
        echo "  (none found in $LOG_DIR)"
      fi
    else
      echo "  (log directory not found: $LOG_DIR)"
    fi
    exit 1
  fi

  local log_file="$1"
  shift

  if [ ! -f "$log_file" ]; then
    echo "File not found: $log_file" >&2
    exit 1
  fi

  cat "$log_file" | "$PIPELINE_DIR/lib/log-formatter.sh" "$@"
}

# =============================================================================
# Main dispatch
# =============================================================================
if [ $# -eq 0 ]; then
  show_help
  exit 0
fi

COMMAND="$1"
shift

case "$COMMAND" in
  orchestrate)
    cmd_orchestrate "$@"
    ;;
  pipeline)
    cmd_pipeline "$@"
    ;;
  run)
    cmd_run "$@"
    ;;
  generate)
    if [ $# -eq 0 ]; then
      echo "Usage: ca generate <prd|context> [options]" >&2
      exit 1
    fi
    SUBCOMMAND="$1"
    shift
    case "$SUBCOMMAND" in
      prd)
        cmd_generate_prd "$@"
        ;;
      context)
        cmd_generate_context "$@"
        ;;
      *)
        echo "Unknown generate subcommand: $SUBCOMMAND" >&2
        echo "Usage: ca generate <prd|context> [options]" >&2
        exit 1
        ;;
    esac
    ;;
  monitor)
    cmd_monitor "$@"
    ;;
  logs)
    cmd_logs "$@"
    ;;
  help|--help|-h)
    show_help
    ;;
  *)
    echo "Unknown command: $COMMAND" >&2
    echo ""
    show_help
    exit 1
    ;;
esac
