{
  "name": "Project Name",
  "description": "Brief description of what this manifest delivers.",
  "devcontainer": "./.devcontainer/agent",
  "max_iterations": 2,
  "agent_max_iterations": {
    "developer": 4
  },
  "epics": [
    {
      "name": "1 - Foundation",
      "description": "First batch — sets up the base that later epics may depend on (merge PRs before dependent work).",
      "subtasks": [
        {
          "prd": "./prds/01-example.md",
          "agents": ["architect", "designer"],
          "repositories": [
            {
              "url": "https://github.com/org/repo-1",
              "branch": "main",
              "context": "./contexts/repo-1",
              "agents": ["developer", "tester", "reviewer"]
            }
          ]
        },
        {
          "prd": "./prds/02-parallel-work.md",
          "agents": ["architect"],
          "repositories": [
            {
              "url": "https://github.com/org/repo-2",
              "branch": "develop",
              "context": "./contexts/repo-2",
              "agents": ["developer", "tester"]
            },
            {
              "url": "https://github.com/org/shared-lib",
              "branch": "main",
              "context": "./contexts/shared-lib",
              "agents": ["developer"]
            }
          ]
        }
      ]
    },
    {
      "name": "2 - Feature Work",
      "description": "Depends on prior work being merged. This epic can run in parallel with other epics; subtasks inside it still run one after another.",
      "subtasks": [
        {
          "prd": "./prds/03-feature.md",
          "repositories": [
            {
              "url": "https://github.com/org/repo-1",
              "branch": "main",
              "context": "./contexts/repo-1"
            }
          ]
        }
      ]
    }
  ]
}
